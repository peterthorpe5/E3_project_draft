"""Production Snakemake workflow for Milestone 1 E3-seeded clustering."""

import os
from pathlib import Path

CONFIG_PATH = Path(
    os.environ.get("E3_DISCOVERY_CONFIG", "config/config.yaml")
).resolve()
configfile: str(CONFIG_PATH)

CONFIG_DIR = CONFIG_PATH.parent


def resolve_config_path(value):
    """Resolve a configuration path relative to the configuration file.

    Args:
        value: Absolute or configuration-relative filesystem path.

    Returns:
        Fully resolved absolute path with a leading user-home marker expanded.
    """
    path = Path(str(value)).expanduser()
    if not path.is_absolute():
        path = CONFIG_DIR / path
    return path.resolve()


ROOT = resolve_config_path(config["outputs"]["root"])
ENVIRONMENT = str(resolve_config_path(config["software"]["environment"]))
BENCHMARK_REPEATS = int(config["benchmarking"].get("repeats", 1))

COMBINED_FASTA = ROOT / "prepared_inputs" / "combined_proteomes.fasta"
SEQUENCES_PARQUET = ROOT / "prepared_inputs" / "sequence_records.parquet"
SAMPLE_SUMMARY = ROOT / "qc" / "sample_summary.tsv"
SEEDS_TSV = ROOT / "prepared_inputs" / "known_e3_seeds.tsv"
SEEDS_PARQUET = ROOT / "prepared_inputs" / "known_e3_seeds.parquet"
DIAMOND_DB = ROOT / "diamond" / "combined_proteomes.dmnd"
CLUSTERS_TSV = ROOT / "diamond" / "raw_deepclust_membership.tsv"
CLUSTERS_PARQUET = ROOT / "parquet" / "raw_deepclust_membership.parquet"
REALIGN_TSV = ROOT / "diamond" / "realigned_membership.tsv"
REALIGN_PARQUET = ROOT / "parquet" / "realigned_membership.parquet"
RESOURCE_DB = ROOT / "duckdb" / "e3_discovery_resource.duckdb"
VALIDATION = ROOT / "qc" / "resource_validation.tsv"
BENCHMARK_SUMMARY = ROOT / "benchmark_summary" / "benchmark_summary.tsv"
RUN_MANIFEST = ROOT / "provenance" / "run_manifest.json"
RESOURCE_METRICS_DIR = ROOT / "resource_metrics"
RESOURCE_USAGE_RECORDS = (
    ROOT / "benchmark_summary" / "resource_usage_records.tsv"
)
RESOURCE_USAGE_SUMMARY = (
    ROOT / "benchmark_summary" / "resource_usage_summary.tsv"
)
PEAK_RAM_PNG = ROOT / "benchmark_summary" / "peak_ram_by_stage.png"
PEAK_RAM_PDF = ROOT / "benchmark_summary" / "peak_ram_by_stage.pdf"
KEY_METRICS = ROOT / "summaries" / "workflow_key_metrics.tsv"
REALIGNMENT_SUMMARY = (
    ROOT / "summaries" / "realignment_content_summary.tsv"
)
SAMPLE_E3_SUMMARY = ROOT / "summaries" / "sample_e3_summary.tsv"
CROSS_SPECIES_SUMMARY = (
    ROOT / "summaries" / "e3_seeded_cross_species_summary.tsv"
)
CLUSTER_SIZE_SUMMARY = (
    ROOT / "summaries" / "e3_seeded_cluster_size_distribution.tsv"
)
CLUSTER_SUMMARY = ROOT / "summaries" / "e3_seeded_cluster_summary.tsv"

RESOURCE_METRIC_FILES = {
    "prepare": RESOURCE_METRICS_DIR / "prepare_inputs.tsv",
    "makedb": RESOURCE_METRICS_DIR / "diamond_makedb.tsv",
    "deepclust": RESOURCE_METRICS_DIR / "diamond_deepclust.tsv",
    "realign": RESOURCE_METRICS_DIR / "diamond_realign.tsv",
    "convert_clusters": (
        RESOURCE_METRICS_DIR / "convert_cluster_membership.tsv"
    ),
    "convert_realignments": (
        RESOURCE_METRICS_DIR / "convert_realignments.tsv"
    ),
    "build_resource": RESOURCE_METRICS_DIR / "build_resource.tsv",
}

rule all:
    input:
        RESOURCE_DB,
        VALIDATION,
        BENCHMARK_SUMMARY,
        RESOURCE_USAGE_RECORDS,
        RESOURCE_USAGE_SUMMARY,
        PEAK_RAM_PNG,
        PEAK_RAM_PDF,
        RUN_MANIFEST,
        KEY_METRICS,
        REALIGNMENT_SUMMARY,
        SAMPLE_E3_SUMMARY,
        CROSS_SPECIES_SUMMARY,
        CLUSTER_SIZE_SUMMARY,
        CLUSTER_SUMMARY,
        ROOT / "fasta_exports" / "e3_seeded_representatives.fasta",
        ROOT / "fasta_exports" / "e3_seeded_all_members.fasta",
        ROOT / "fasta_exports" / "e3_seeded_strict_members.fasta",
        ROOT / "fasta_exports" / "all_matched_e3_seeds.fasta",
        ROOT / "fasta_exports" / "strict_matched_e3_seeds.fasta",
        ROOT / "fasta_exports" / "strict_nonseed_candidates.fasta",

rule prepare_inputs:
    output:
        fasta=ensure(COMBINED_FASTA, non_empty=True),
        sequences=ensure(SEQUENCES_PARQUET, non_empty=True),
        sample_summary=ensure(SAMPLE_SUMMARY, non_empty=True),
        seeds_tsv=ensure(SEEDS_TSV, non_empty=True),
        seeds_parquet=ensure(SEEDS_PARQUET, non_empty=True),
        metrics=ensure(RESOURCE_METRIC_FILES["prepare"], non_empty=True),
    log:
        ROOT / "logs" / "prepare_inputs.log",
    benchmark:
        repeat(ROOT / "benchmarks" / "prepare_inputs.tsv", BENCHMARK_REPEATS),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} prepare \
          --config {CONFIG_PATH:q} > {log:q} 2>&1
        """

rule make_diamond_database:
    input:
        COMBINED_FASTA,
    output:
        database=ensure(DIAMOND_DB, non_empty=True),
        metrics=ensure(RESOURCE_METRIC_FILES["makedb"], non_empty=True),
    log:
        ROOT / "logs" / "diamond_makedb_rule.log",
    benchmark:
        repeat(ROOT / "benchmarks" / "diamond_makedb.tsv", BENCHMARK_REPEATS),
    threads:
        int(config["resources"]["threads"]),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} diamond-makedb \
          --config {CONFIG_PATH:q} > {log:q} 2>&1
        """

