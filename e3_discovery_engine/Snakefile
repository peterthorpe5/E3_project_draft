    log:
        ROOT / "logs" / "diamond_deepclust_rule.log",
    benchmark:
        repeat(ROOT / "benchmarks" / "diamond_deepclust.tsv", BENCHMARK_REPEATS),
    threads:
        int(config["resources"]["threads"]),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} diamond-deepclust \
          --config {CONFIG_PATH:q} > {log:q} 2>&1
        """

rule realign_clusters:
    input:
        database=DIAMOND_DB,
        clusters=CLUSTERS_TSV,
    output:
        realignments=ensure(REALIGN_TSV, non_empty=True),
        metrics=ensure(RESOURCE_METRIC_FILES["realign"], non_empty=True),
    log:
        ROOT / "logs" / "diamond_realign_rule.log",
    benchmark:
        repeat(ROOT / "benchmarks" / "diamond_realign.tsv", BENCHMARK_REPEATS),
    threads:
        int(config["resources"]["threads"]),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} diamond-realign \
          --config {CONFIG_PATH:q} > {log:q} 2>&1
        """

rule convert_cluster_membership:
    input:
        CLUSTERS_TSV,
    output:
        parquet=ensure(CLUSTERS_PARQUET, non_empty=True),
        metrics=ensure(
            RESOURCE_METRIC_FILES["convert_clusters"],
            non_empty=True,
        ),
    log:
        ROOT / "logs" / "convert_cluster_membership.log",
    benchmark:
        repeat(
            ROOT / "benchmarks" / "convert_cluster_membership.tsv",
            BENCHMARK_REPEATS,
        ),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} convert-clusters \
          --input {input:q} --output {output.parquet:q} > {log:q} 2>&1
        """

rule convert_realignments:
    input:
        REALIGN_TSV,
    output:
        parquet=ensure(REALIGN_PARQUET, non_empty=True),
        metrics=ensure(
            RESOURCE_METRIC_FILES["convert_realignments"],
            non_empty=True,
        ),
    log:
        ROOT / "logs" / "convert_realignments.log",
    benchmark:
        repeat(
            ROOT / "benchmarks" / "convert_realignments.tsv",
            BENCHMARK_REPEATS,
        ),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} convert-realignments \
          --config {CONFIG_PATH:q} --input {input:q} \
          --output {output.parquet:q} > {log:q} 2>&1
        """

rule build_resource:
    input:
        sequences=SEQUENCES_PARQUET,
        seeds=SEEDS_PARQUET,
        clusters=CLUSTERS_PARQUET,
        realignments=REALIGN_PARQUET,
    output:
        database=ensure(RESOURCE_DB, non_empty=True),
        validation=ensure(VALIDATION, non_empty=True),
        representatives=ensure(
            ROOT / "fasta_exports" / "e3_seeded_representatives.fasta",
            non_empty=True,
        ),
        all_members=ensure(
            ROOT / "fasta_exports" / "e3_seeded_all_members.fasta",
            non_empty=True,
        ),
        strict_members=ROOT / "fasta_exports" / "e3_seeded_strict_members.fasta",
        all_matched_seeds=ROOT / "fasta_exports" / "all_matched_e3_seeds.fasta",
        strict_matched_seeds=(
            ROOT / "fasta_exports" / "strict_matched_e3_seeds.fasta"
        ),
        strict_nonseed_candidates=(
            ROOT / "fasta_exports" / "strict_nonseed_candidates.fasta"
        ),
        key_metrics=ensure(KEY_METRICS, non_empty=True),
        realignment_summary=ensure(REALIGNMENT_SUMMARY, non_empty=True),
        sample_summary=ensure(SAMPLE_E3_SUMMARY, non_empty=True),
        cross_species_summary=ensure(CROSS_SPECIES_SUMMARY, non_empty=True),
        cluster_size_summary=ensure(CLUSTER_SIZE_SUMMARY, non_empty=True),
        cluster_summary=ensure(CLUSTER_SUMMARY, non_empty=True),
        metrics=ensure(
            RESOURCE_METRIC_FILES["build_resource"],
            non_empty=True,
        ),
    log:
        ROOT / "logs" / "build_resource.log",
    benchmark:
        repeat(ROOT / "benchmarks" / "build_resource.tsv", BENCHMARK_REPEATS),
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli \
          --resource-metrics {output.metrics:q} build-resource \
          --config {CONFIG_PATH:q} > {log:q} 2>&1
        """

rule aggregate_benchmarks:
    input:
        database=RESOURCE_DB,
        resource_metrics=list(RESOURCE_METRIC_FILES.values()),
    output:
        benchmark=ensure(BENCHMARK_SUMMARY, non_empty=True),
        resource_records=ensure(RESOURCE_USAGE_RECORDS, non_empty=True),
        resource_summary=ensure(RESOURCE_USAGE_SUMMARY, non_empty=True),
        peak_ram_png=ensure(PEAK_RAM_PNG, non_empty=True),
        peak_ram_pdf=ensure(PEAK_RAM_PDF, non_empty=True),
    params:
        benchmark_dir=ROOT / "benchmarks",
        resource_metrics_dir=RESOURCE_METRICS_DIR,
        output_dir=ROOT / "benchmark_summary",
    log:
        ROOT / "logs" / "aggregate_benchmarks.log",
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli aggregate-benchmarks \
          --benchmark-dir {params.benchmark_dir:q} \
          --resource-metrics-dir {params.resource_metrics_dir:q} \
          --output-dir {params.output_dir:q} > {log:q} 2>&1
        """

rule write_provenance:
    input:
        RESOURCE_DB,
        BENCHMARK_SUMMARY,
        RESOURCE_USAGE_SUMMARY,
        KEY_METRICS,
        REALIGNMENT_SUMMARY,
    output:
        ensure(RUN_MANIFEST, non_empty=True),
    log:
        ROOT / "logs" / "write_provenance.log",
    conda:
        ENVIRONMENT
    shell:
        """
        set -euo pipefail
        mkdir -p "$(dirname {log:q})"
        PYTHONPATH=src python -m e3_discovery.cli write-provenance \
          --config {CONFIG_PATH:q} > {log:q} 2>&1
        """
