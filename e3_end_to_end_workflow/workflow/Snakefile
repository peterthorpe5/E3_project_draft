"""Top-level, configuration-driven E3 project workflow."""

from pathlib import Path

from e3workflow.config import STAGE_NAMES, load_config, stage_dependencies
from e3workflow.control import stage_token_path


CONFIG_PATH = Path(workflow.configfiles[0]).resolve()
E3_CONFIG = load_config(CONFIG_PATH)
RUN_ROOT = E3_CONFIG.run_root
STAGE_PATTERN = "|".join(STAGE_NAMES)


def stage_inputs(wildcards):
    """Resolve scientific prerequisites, controlled inputs and the rerun token."""

    inputs = [str(stage_token_path(E3_CONFIG, wildcards.stage))]
    dependencies = stage_dependencies(wildcards.stage)
    if not dependencies:
        inputs.extend([
            str(CONFIG_PATH),
            str(E3_CONFIG.proteomes_manifest),
            str(E3_CONFIG.seeds_manifest),
            str(E3_CONFIG.shortlist_manifest),
        ])
    inputs.extend(
        str(RUN_ROOT / dependency / "stage_manifest.json")
        for dependency in dependencies
    )
    return inputs


rule all:
    input:
        str(RUN_ROOT / STAGE_NAMES[-1] / "stage_manifest.json")


rule run_stage:
    input:
        stage_inputs
    output:
        str(RUN_ROOT / "{stage}" / "stage_manifest.json")
    params:
        config=str(CONFIG_PATH)
    threads:
        lambda wildcards: E3_CONFIG.stage(wildcards.stage).threads
    resources:
        mem_mb=lambda wildcards: E3_CONFIG.stage(wildcards.stage).memory_mb,
        runtime=lambda wildcards: E3_CONFIG.stage(wildcards.stage).runtime_minutes
    log:
        str(RUN_ROOT / "workflow_logs" / "{stage}.snakemake.log")
    conda:
        "../environment.yml"
    wildcard_constraints:
        stage=STAGE_PATTERN
    shell:
        """
        set -o pipefail
        e3-workflow run-stage --config {params.config:q} --stage {wildcards.stage:q} \
            --verbose 2>&1 | tee {log:q}
        """
