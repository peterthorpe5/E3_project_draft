"""Top-level, configuration-driven E3 project workflow."""

from pathlib import Path

from e3workflow.config import STAGE_NAMES, controlled_input_paths, load_config, stage_dependencies
from e3workflow.control import stage_token_path


CONFIG_PATH = Path(workflow.configfiles[0]).resolve()
E3_CONFIG = load_config(CONFIG_PATH)
RUN_ROOT = E3_CONFIG.run_root
STAGE_PATTERN = "|".join(STAGE_NAMES)
STAGE_MANIFESTS = [
    str(RUN_ROOT / stage_name / "stage_manifest.json")
    for stage_name in STAGE_NAMES
]
STAGE_REPORTS = [
    str(RUN_ROOT / stage_name / "report" / "stage_report.html")
    for stage_name in STAGE_NAMES
]
BENCHMARK_ROOT = RUN_ROOT / "benchmark_summary"
BENCHMARK_MANIFEST = BENCHMARK_ROOT / "benchmark_manifest.json"
REPORT_ROOT = RUN_ROOT / "reports"
RUN_REPORT = REPORT_ROOT / "e3_workflow_summary.html"
REPORT_MANIFEST = REPORT_ROOT / "report_manifest.json"


def stage_inputs(wildcards):
    """Resolve scientific prerequisites, controlled inputs and the rerun token."""

    inputs = [str(stage_token_path(E3_CONFIG, wildcards.stage))]
    dependencies = stage_dependencies(wildcards.stage)
    if not dependencies:
        inputs.append(str(CONFIG_PATH))
        inputs.extend(str(path) for _, path in controlled_input_paths(E3_CONFIG))
    inputs.extend(
        str(RUN_ROOT / dependency / "stage_manifest.json")
        for dependency in dependencies
    )
    return inputs


rule all:
    input:
        final_stage=str(RUN_ROOT / STAGE_NAMES[-1] / "stage_manifest.json"),
        benchmark_manifest=str(BENCHMARK_MANIFEST),
        stage_resources=str(BENCHMARK_ROOT / "stage_resource_summary.tsv"),
        workflow_resources=str(BENCHMARK_ROOT / "workflow_resource_summary.tsv"),
        stage_reports=STAGE_REPORTS,
        run_report=str(RUN_REPORT),
        report_manifest=str(REPORT_MANIFEST)


rule generate_run_report:
    input:
        manifests=STAGE_MANIFESTS,
        stage_reports=STAGE_REPORTS,
        benchmark_manifest=str(BENCHMARK_MANIFEST),
        stage_resources=str(BENCHMARK_ROOT / "stage_resource_summary.tsv"),
        workflow_resources=str(BENCHMARK_ROOT / "workflow_resource_summary.tsv")
    output:
        html=str(RUN_REPORT),
        manifest=str(REPORT_MANIFEST),
        complete=str(REPORT_ROOT / "report_complete.tsv")
    params:
        config=str(CONFIG_PATH),
        output_dir=lambda wildcards, output: str(Path(output.html).parent)
    threads:
        1
    resources:
        mem_mb=4000,
        runtime=30
    log:
        str(RUN_ROOT / "workflow_logs" / "generate_report.snakemake.log")
    conda:
        "../environment.yml"
    shell:
        """
        set -o pipefail
        e3-workflow generate-report --config {params.config:q} \
            --output-dir {params.output_dir:q} 2>&1 | tee {log:q}
        """


rule aggregate_benchmarks:
    input:
        STAGE_MANIFESTS
    output:
        manifest=str(BENCHMARK_MANIFEST),
        stage_resources=str(BENCHMARK_ROOT / "stage_resource_summary.tsv"),
        workflow_resources=str(BENCHMARK_ROOT / "workflow_resource_summary.tsv"),
        slurm_status=str(BENCHMARK_ROOT / "slurm_accounting_status.tsv"),
        slurm_records=str(BENCHMARK_ROOT / "slurm_accounting.tsv"),
        complete=str(BENCHMARK_ROOT / "benchmark_complete.tsv")
    params:
        config=str(CONFIG_PATH),
        output_dir=lambda wildcards, output: str(Path(output.manifest).parent)
    threads:
        1
    resources:
        mem_mb=4000,
        runtime=30
    log:
        str(RUN_ROOT / "workflow_logs" / "aggregate_benchmarks.snakemake.log")
    conda:
        "../environment.yml"
    shell:
        """
        set -o pipefail
        e3-workflow aggregate-benchmarks --config {params.config:q} \
            --output-dir {params.output_dir:q} 2>&1 | tee {log:q}
        """


rule run_stage:
    input:
        stage_inputs
    output:
        manifest=str(RUN_ROOT / "{stage}" / "stage_manifest.json"),
        report=str(RUN_ROOT / "{stage}" / "report" / "stage_report.html")
    params:
        config=str(CONFIG_PATH)
    threads:
        lambda wildcards: E3_CONFIG.stage(wildcards.stage).threads
    resources:
        mem_mb=lambda wildcards: E3_CONFIG.stage(wildcards.stage).memory_mb,
        runtime=lambda wildcards: E3_CONFIG.stage(wildcards.stage).runtime_minutes
    log:
        str(RUN_ROOT / "workflow_logs" / "{stage}.snakemake.log")
    conda:
        "../environment.yml"
    wildcard_constraints:
        stage=STAGE_PATTERN
    shell:
        """
        set -o pipefail
        e3-workflow run-stage --config {params.config:q} --stage {wildcards.stage:q} \
            --verbose 2>&1 | tee {log:q}
        """
